        TS_PUB["Public Landing Page\nProgramme info, Apply button"]
        TS_APP["Trainer Application\nName, location, niche, social media"]
        TS_ONB["Onboarding\nVideos + quiz"]
        TS_DSH["Trainer Dashboard\nCodes, clients, commissions"]
        TS_ADM["Admin Panel\nAll data, region filter"]
        TS_PAY["Commission Payouts\nBatch payouts via Wise"]
