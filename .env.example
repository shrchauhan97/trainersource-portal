# Supabase — required for the app to boot.
# The NEXT_PUBLIC_ vars are read by the browser-facing Supabase SSR client.
# SUPABASE_URL / SUPABASE_ANON_KEY are also read by server-only code paths
# (webhook handler, integration tests) and fall back to the NEXT_PUBLIC_ values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# BigCommerce API — customer sync + order fetches from the webhook handler.
BIGCOMMERCE_STORE_HASH=
BIGCOMMERCE_ACCESS_TOKEN=

# BigCommerce webhook auth — MUST be a separate, dedicated secret.
# Do NOT reuse BIGCOMMERCE_ACCESS_TOKEN here.
# Configure the BC webhook destination with either:
#   (a) Authorization: Bearer <this-value>, or
#   (b) HMAC signing key (X-BC-Webhook-Signature header) set to <this-value>.
BIGCOMMERCE_WEBHOOK_SECRET=

# Access gate CORS allowlist — comma-separated origins.
# Defaults to https://ultimate-peptides.com when unset.
ACCESS_GATE_ALLOWED_ORIGINS=https://ultimate-peptides.com

# Access gate session token — HMAC secret used to sign the session tokens
# handed to the storefront after a successful code validation. The storefront
# stores the token in localStorage; every page load it calls /api/session/check
# which verifies the signature + checks the customer still exists. Without a
# secret here, anyone can set localStorage and bypass the gate (review finding
# C2). Use ≥32 chars of randomness, e.g. `openssl rand -base64 48`.
ACCESS_GATE_SESSION_SECRET=

# Access gate country allowlist — comma-separated country names. Enforced
# server-side on /api/codes/validate (review finding H1). The storefront
# shows a dropdown with the same list, but the endpoint is reachable
# directly so the client-side limit was not a security control. Keep this
# list in sync with the storefront's COUNTRIES array.
ACCESS_GATE_ALLOWED_COUNTRIES=Singapore,UAE,Japan,United States

# Wise (payouts)
WISE_API_KEY=
WISE_PROFILE_ID=

# App
NEXT_PUBLIC_SITE_URL=https://trainersource.com

# Dev-only: enables GET /api/dev/login?email=...&password=...&redirect=... so
# you can sign in with password during local walkthroughs without the magic-link
# email detour. Set to 1 ONLY in local dev environments. The route also refuses
# to run when NODE_ENV=production, but keep this flag off in any shared env.
ENABLE_DEV_LOGIN=

# Peptide Concierge M2 (Reorder Mini App)
# BC app credentials — distinct from BIGCOMMERCE_ACCESS_TOKEN.
# Create a BC App in the store control panel to get these.
# Docs: https://developer.bigcommerce.com/docs/store-operations/customer-login
BC_CLIENT_ID=
BC_CLIENT_SECRET=
BC_STORE_URL=https://ultimate-peptides.com

# Telegram integrations (Partner mode P4 + Mini App initData M1/M2)
# Same Telegram bot token used in Railway — mirror it here on Vercel.
# Used to verify Mini App initData HMAC and Login Widget HMAC.
TELEGRAM_BOT_TOKEN=

# Partner mode — shared secret for bot ↔ portal trainer API calls
BOT_PORTAL_SHARED_SECRET=

# Public Telegram bot username (for Login Widget data-telegram-login)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=peptidebutlerbot

# Sentry error + performance monitoring.
# NEXT_PUBLIC_SENTRY_DSN is read by the browser bundle (client init); SENTRY_DSN
# is the server/edge equivalent. Both can be the same DSN value. When unset,
# Sentry stays inert (no events sent) — safe for local dev.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Build-time source-map upload (optional). Only runs when SENTRY_AUTH_TOKEN is
# set (e.g. in CI / Vercel build). Create a token with project:releases scope.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
